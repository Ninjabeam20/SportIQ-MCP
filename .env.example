# sportiq-mcp environment variables
# Copy to .env and fill in. .env is gitignored.

# --- Data source API keys ---
CRICAPI_KEY=
APIFOOTBALL_KEY=

# --- Cache backend ---
REDIS_URL=  # Optional — leave unset to use diskcache for local dev

# --- Logging ---
SPORTIQ_LOG_LEVEL=INFO
SPORTIQ_LOG_FORMAT=pretty  # pretty | json
