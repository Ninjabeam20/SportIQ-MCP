# sportiq-mcp environment variables
# Copy to .env and fill in. .env is gitignored.
#
# NOTE: the built-in pydantic-settings dotenv parser does NOT strip inline
# comments (python-dotenv is not a dependency). Keep every comment on its own
# line — never trailing a VAR=value, or the comment becomes part of the value
# (bool/Literal fields then fail validation and the server won't boot).

# --- Cricket data sources ---
# cricapi.com (a.k.a. cricketdata.org portal) — 100 req/day free; primary for live/fixtures/standings/squad
CRICAPI_KEY=
# rapidapi.com Cricbuzz mirror — paid escape hatch; opt-in.
# Also: paste this key into the <RAPIDAPI_KEY> placeholders in .mcp.json to enable the RapidAPI Hub MCP servers.
RAPIDAPI_KEY=
# Set to 1 to enable the NDTV Sports scraper (opt-in; operator accepts ToS risk)
SPORTIQ_ENABLE_NDTV=
# Set to 1 to enable the Cricbuzz scraper (opt-in; operator accepts ToS risk)
SPORTIQ_ENABLE_CRICBUZZ=

# --- Football data sources ---
# api-football.com — 100 req/day free
APIFOOTBALL_KEY=
# football-data.org — optional higher-tier token (works token-less at lower limits)
FOOTBALLDATA_KEY=

# --- Odds (cricket + football) ---
# the-odds-api.com — 500 req/month free; shared across cricket + football odds
THEODDS_KEY=

# --- Cache backend ---
# Optional — leave unset to use diskcache for local dev
REDIS_URL=

# --- Logging ---
SPORTIQ_LOG_LEVEL=INFO
# pretty | json
SPORTIQ_LOG_FORMAT=pretty
