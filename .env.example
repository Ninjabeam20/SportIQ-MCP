# sportiq-mcp environment variables
# Copy to .env and fill in. .env is gitignored.

# --- Cricket data sources ---
CRICAPI_KEY=                    # cricapi.com — 100 req/day free; primary for live/fixtures/standings/squad
RAPIDAPI_KEY=                   # rapidapi.com Cricbuzz mirror — paid escape hatch; opt-in
SPORTIQ_ENABLE_NDTV=            # Set to 1 to enable NDTV Sports scraper (opt-in; operator accepts ToS risk)
SPORTIQ_ENABLE_CRICBUZZ=        # Set to 1 to enable Cricbuzz scraper (opt-in; operator accepts ToS risk)

# --- Football data sources ---
APIFOOTBALL_KEY=                # api-football.com — 100 req/day free

# --- Odds (cricket + football) ---
THEODDS_KEY=                    # the-odds-api.com — 500 req/month free; shared across cricket + football odds

# --- Cache backend ---
REDIS_URL=                      # Optional — leave unset to use diskcache for local dev

# --- Logging ---
SPORTIQ_LOG_LEVEL=INFO
SPORTIQ_LOG_FORMAT=pretty       # pretty | json
