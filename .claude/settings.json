{
  "permissions": {
    "allow": [
      "Bash(uv sync)",
      "Bash(uv sync --extra dev)",
      "Bash(uv run pytest*)",
      "Bash(uv run ruff*)",
      "Bash(uv run python*)",
      "Bash(uv build)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(grep*)",
      "Bash(rg*)",
      "Bash(ls*)",
      "Bash(find*)"
    ],
    "deny": []
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/format-on-save.sh" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/block-dangerous-bash.sh" }
        ]
      }
    ]
  }
}
